  "tips": [
    {
      "id": 1,
      "topic": "imie_vs_nazwa",
      "content": "Use 'imię' for people and pets. For things and places, use 'nazwa'.",
      "examples": [
        "Ona ma polskie imię. = She has a Polish name.",
        "Nazwa tej restauracji jest ciekawa. = The name of this restaurant is interesting."
      ]
    },
    {
      "id": 2,
      "topic": "introducing_yourself",
      "content": "When introducing yourself, use one of these patterns: 'mieć na imię + name', 'nazywać się + surname/name', or 'być + name/surname'.",
      "examples": [
        "Mam na imię Adam.",
        "Nazywam się Kowalski / Adam Kowalski.",
        "Jestem Adam / Adam Kowalski."
      ]
    },
    {
      "id": 3,
      "topic": "name_after_introduction_patterns",
      "content": "After 'mam na imię', use only your first name. After 'nazywam się', use surname or first name + surname. After 'jestem', you may use your first name or full name."
    },
    {
      "id": 4,
      "topic": "small_talk_questions",
      "content": "Other common questions: 'Co (tam) nowego u ciebie?', 'Jak leci?', 'Jak żyjesz?'",
      "examples": [
        "Co tam nowego u ciebie? = What's new with you?",
        "Jak leci? = How is it going?",
        "Jak żyjesz? = How's life?"
      ]
    },
    {
      "id": 5,
      "topic": "small_talk_answers",
      "content": "Common answers to 'What's up?' or 'How's it going?' include:",
      "examples": [
        "świetnie = great",
        "wszystko OK = everything's OK",
        "nic nowego / po staremu = same old, same old",
        "tak sobie = so-so",
        "nieźle = not bad",
        "fatalnie = really bad, terrible"
      ]
    },
    {
      "id": 6,
      "topic": "formal_question_with_pan_pani",
      "content": "You can also say 'Jak się pan nazywa?'. With 'pan' or 'pani', Polish uses 3rd-person singular verb forms."
    },
    {
      "id": 10,
      "topic": "moge_prosic_not_moge_miec",
      "content": "The verb 'móc' is irregular. Use 'Czy mogę prosić...?' rather than 'Czy mogę mieć...?' when asking for something like a phone number.",
      "examples": [
        "Czy mogę prosić twój numer telefonu?",
        "Czy mogę prosić o twój numer telefonu?"
      ]
    },
    {
      "id": 14,
      "topic": "prosze_meanings",
      "content": "'proszę' can mean both 'please' and 'here you are', depending on context."
    },
    {
      "id": 17,
      "topic": "softened_names",
      "content": "Some Polish names have informal softened versions.",
      "examples": [
        "Agnieszka -> Aga",
        "Katarzyna -> Kasia",
        "Bartosz -> Bartek"
      ]
    },
    {
      "id": 18,
      "topic": "social_media_platform_names",
      "content": "Say 'na Instagramie' and 'na Facebooku'. You may also hear 'Masz Instagrama/Facebooka?'"
    },
    {
      "id": 19,
      "topic": "nice_to_meet_you_responses",
      "content": "For 'Miło mi cię poznać!' or 'Miło mi!', possible replies include the same phrase, 'nawzajem', 'wzajemnie', or 'mnie również'. 'Nawzajem' and 'wzajemnie' can also be used to return wishes.",
      "examples": [
        "Miłego dnia! — Nawzajem!",
        "Smacznego! — Wzajemnie!"
      ]
    },
    {
      "id": 20,
      "topic": "seeing_again",
      "content": "Use 'Miło mi cię widzieć' when meeting someone again."
    },
    {
      "id": 22,
      "topic": "urodziny_plural",
      "content": "'Urodziny' is plural in Polish, so it takes a plural verb.",
      "examples": [
        "Kiedy są twoje urodziny?"
      ]
    },
    {
      "id": 23,
      "topic": "age_uses_miec",
      "content": "When talking about age, Polish uses 'mieć' (to have), not 'być' (to be).",
      "examples": [
        "Mam 34 lata. = I'm 34."
      ]
    },
    {
      "id": 24,
      "topic": "wolny_multiple_meanings",
      "content": "The adjective 'wolny' can also mean free, slow, or available, not only single."
    },
    {
      "id": 25,
      "topic": "my_moja_moje",
      "content": "Polish nouns have genders. Use 'mój' before masculine nouns, 'moja' before feminine nouns, and 'moje' before neuter nouns.",
      "examples": [
        "mój chłopak",
        "moja żona",
        "moje imię"
      ]
    },
    {
      "id": 27,
      "topic": "twoj_twoja_twoje",
      "content": "Use 'twój' before masculine nouns, 'twoja' before feminine nouns, and 'twoje' before neuter nouns. 'Chłopak' can mean either boy or boyfriend; 'dziewczyna' can mean girl or girlfriend."
    },
    {
      "id": 32,
      "topic": "sluzbowo",
      "content": "'Służbowo' means 'on business'."
    },
    {
      "id": 34,
      "topic": "languages_lowercase",
      "content": "In Polish, language names are written in lowercase.",
      "examples": [
        "polski",
        "angielski"
      ]
    },
    {
      "id": 35,
      "topic": "name_with_miec_na_imie",
      "content": "Do not say 'Jego żona jest Anna' when you mean 'His wife's name is Anna'. Use 'mieć na imię'.",
      "examples": [
        "Jego żona ma na imię Anna.",
        "Moja mama ma na imię Maria."
      ]
    }
  ],
