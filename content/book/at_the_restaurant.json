      ]
    },
    {
      "id": 1,
      "topic": "polecac_accusative",
      "content": "Use the accusative after the verb 'polecać' (to recommend)."
    },
    {
      "id": 3,
      "topic": "prosze_or_poprosze_in_restaurant",
      "content": "In a restaurant or store, you can often use either 'proszę' or 'poproszę'. 'poproszę' sounds slightly more polite or more natural in many ordering contexts."
    },
    {
      "id": 5,
      "topic": "menu_sections",
      "content": "Useful names of menu sections:",
      "examples": [
        "przystawki = appetisers, starters",
        "dania główne = main courses",
        "dodatki = side dishes",
        "desery = desserts",
        "napoje = beverages"
      ]
    },
    {
      "id": 8,
      "topic": "stolik_vs_stol",
      "content": "'stolik' can refer to a restaurant table, coffee table, or bedside table. A regular dining-room table is 'stół'."
    },
    {
      "id": 8,
      "topic": "dla_dwoch_osob_pattern",
      "content": "Useful memorised phrases after 'dla':",
      "examples": [
        "dla dwóch osób = for two",
        "dla trzech osób = for three",
        "dla czterech osób = for four",
        "dla pięciu osób = for five",
        "dla sześciu osób = for six"
      ]
    },
    {
      "id": 9,
      "topic": "popular_polish_dishes",
      "content": "Examples of popular Polish dishes:",
      "examples": [
        "pierogi = dumplings",
        "bigos = hunter's stew",
        "kopytka = potato dumplings",
        "gołąbki = stuffed cabbage rolls",
        "placki ziemniaczane = potato pancakes"
      ]
    },
    {
      "id": 11,
      "topic": "panstwo_formal_plural",
      "content": "'Państwo' means formal plural 'you'. It is used to politely address more than one person."
    },
    {
      "id": 13,
      "topic": "responses_to_free_taken",
      "content": "Possible replies:",
      "examples": [
        "Nie, wolne. = No, it's vacant/free.",
        "Tak, zajęte. = Yes, it's taken."
      ]
    },
    {
      "id": 15,
      "topic": "czy_moge_short_form",
      "content": "You can shorten some requests to '(Czy) mogę?' meaning 'May I?'. A natural answer is 'Tak, proszę/poproszę.' in the book's usage."
    },
    {
      "id": 22,
      "topic": "czy_jest_vs_czy_sa",
      "content": "Useful pattern: '(Czy) jest...?' means 'Is there...?' and '(Czy) są...?' means 'Are there...?'",
      "examples": [
        "Czy jest sok pomarańczowy? = Is there any orange juice? / Have you got any orange juice?",
        "Czy są dania wegetariańskie? = Are there any vegetarian dishes? / Have you got any vegetarian dishes?"
      ]
    },
    {
      "id": 24,
      "topic": "kazdy_vs_wszyscy",
      "content": "You can say either '(Czy) każdy płaci osobno?' or '(Czy) wszyscy płacą osobno?'. After 'każdy', use a singular verb; after 'wszyscy', use a plural verb."
    },
    {
      "id": 26,
      "topic": "chcialbym_gender",
      "content": "'I would like to' can be translated as 'chciałbym' for masculine speakers and 'chciałabym' for feminine speakers."
    },
    {
      "id": 27,
      "topic": "podac_in_restaurant",
      "content": "The verb 'podać' is common in restaurants and can mean to bring, give, pass, or serve. Use the accusative with it.",
      "examples": [
        "Co podać? = What can I get you?",
        "Co dla pani? = And for you, madam?",
        "Co dla pana? = And for you, sir?"
      ]
    },
    {
      "id": 29,
      "topic": "juz_podaje",
      "content": "If a waiter says 'już podaję', they mean they are just about to bring or serve something."
    },
    {
      "id": 33,
      "topic": "jesc_present_tense",
      "content": "Quick reminder of the present tense of 'jeść' (to eat).",
      "tables": {
        "present_tense": {
          "ja": "jem",
          "ty": "jesz",
          "on_ona_ono": "je",
          "my": "jemy",
          "wy": "jecie",
          "oni_one": "jedzą"
        }
      }
    },
    {
      "id": 34,
      "topic": "knajpa",
      "content": "'knajpa' is a colloquial word for a restaurant, bar, or pub."
    },
    {
      "id": 35,
      "topic": "kolacja_phrase",
      "content": "For now, memorise the phrase 'na kolację' meaning 'for dinner/supper'."
    },
    {
      "id": 36,
      "topic": "najedzony_vs_pelny",
      "content": "If you want to say you have eaten enough, use 'jestem najedzony'. 'pełny' can also mean full in other contexts, such as 'Autobus był pełny'."
    }
  ],
