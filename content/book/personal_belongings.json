  "tips": [
    {
      "id": 1,
      "topic": "aparat_vs_kamera",
      "content": "There is a Polish word 'kamera', but it translates as 'camera' only when referring to a video camera. For a regular camera, use 'aparat (fotograficzny)'."
    },
    {
      "id": 2,
      "topic": "palic_papierosy",
      "content": "'Palić (papierosy)' means 'to smoke (cigarettes)'."
    },
    {
      "id": 2,
      "topic": "oni_vs_one_and_plural_adjectives",
      "content": "Polish has two plural third-person pronouns meaning 'they': 'oni' and 'one'. 'oni' is used for masculine-personal groups; 'one' for non-masculine-personal groups. The tip also reminds that some adjectives change accordingly.",
      "examples": [
        "papierosy nie są zdrowe",
        "duże banany",
        "małe domy",
        "zdrowe warzywa"
      ]
    },
    {
      "id": 3,
      "topic": "chciec_present_tense",
      "content": "Present tense of 'chcieć' (to want).",
      "tables": {
        "present_tense": {
          "ja": "chcę",
          "ty": "chcesz",
          "on_ona_ono": "chce",
          "my": "chcemy",
          "wy": "chcecie",
          "oni_one": "chcą"
        }
      }
    },
    {
      "id": 4,
      "topic": "zegarek_vs_zegar",
      "content": "Do not confuse 'zegarek' (watch) with 'zegar' (clock)."
    },
    {
      "id": 9,
      "topic": "pozyczyc_meaning",
      "content": "'Pożyczyć' can mean either 'to borrow' or 'to lend' depending on context."
    },
    {
      "id": 10,
      "topic": "sunglasses_translation",
      "content": "'Sunglasses' is translated as 'okulary przeciwsłoneczne' or informally 'okulary słoneczne'."
    },
    {
      "id": 11,
      "topic": "gotowy_do_odbioru",
      "content": "'gotowy/gotowa/gotowe do odbioru' can be translated as 'ready for pickup'."
    },
    {
      "id": 13,
