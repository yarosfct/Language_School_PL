  "tips": [
    {
      "id": 1,
      "topic": "tatus_i_mamusia",
      "content": "More affectionately, parents can also be called 'tatuś' (daddy) and 'mamusia' (mummy)."
    },
    {
      "id": 1,
      "topic": "city_names_with_w",
      "content": "When saying 'in' certain Polish cities, the city name changes form.",
      "examples": [
        "Kraków -> w Krakowie",
        "Wrocław -> we Wrocławiu",
        "Warszawa -> w Warszawie",
        "Łódź -> w Łodzi",
        "Gdańsk -> w Gdańsku"
      ]
    },
    {
      "id": 3,
      "topic": "age_with_miec",
      "content": "When talking about age, Polish most often uses 'mieć' (to have), e.g. 'Ona ma 10 lat'. You add 'lat' or 'lata' after the number.",
      "examples": [
        "Ona ma 10 lat. = She is 10 years old.",
        "po trzydziestce = in one's thirties"
      ]
    },
    {
      "id": 5,
      "topic": "na_emeryturze",
      "content": "'na emeryturze' means 'retired' (literally on a pension)."
    },
    {
      "id": 8,
      "topic": "collective_numerals_with_children",
      "content": "In Polish, collective numerals are used for groups of children. Instead of ordinary numerals, use forms like 'dwoje', 'troje', 'czworo', 'pięcioro', 'sześcioro'.",
      "examples": [
        "Oni mają troje dzieci. = They have three children.",
        "dzieci is the irregular plural of dziecko"
      ]
    },
    {
      "id": 12,
      "topic": "nasz_nasza_nasze",
      "content": "In the singular, 'our' can be expressed as 'nasz' (masculine), 'nasza' (feminine), or 'nasze' (neuter)."
    },
    {
      "id": 13,
      "topic": "instrumental_after_byc",
      "content": "After the verb 'być' (to be), Polish often uses the instrumental case in sentences like 'Mój kuzyn jest lekarzem' or 'Jestem jedynakiem'."
    },
    {
      "id": 14,
      "topic": "woman_only_child",
      "content": "A woman would say 'jestem jedynaczką'."
    },
    {
      "id": 17,
      "topic": "rodzenstwo_uncountable",
      "content": "'rodzeństwo' is uncountable in Polish and is always used in the singular form."
    },
    {
      "id": 17,
      "topic": "tez_meaning",
      "content": "Here, 'też' means 'such' in the sentence 'mam tak wspaniałe rodzeństwo' on the English side as rendered by the book context note."
    },
    {
      "id": 18,
      "topic": "w_ciazy",
      "content": "'w ciąży' means 'pregnant'."
    },
    {
      "id": 20,
      "topic": "ze_strony_mamy_taty",
      "content": "Useful family-side phrases:",
      "examples": [
        "ze strony (mojej) mamy = on my mum's side",
        "ze strony (mojego) taty = on my dad's side",
        "dziadkowie = grandparents"
      ]
    },
    {
      "id": 24,
      "topic": "szwagier_vs_bratowa",
      "content": "'Brother-in-law' translates as 'szwagier'. There are two words meaning 'sister-in-law'. 'bratowa' refers to one's brother's wife, while 'szwagierka' is the sister of one's husband."
    },
    {
      "id": 27,
      "topic": "having_brothers_and_sisters",
      "content": "Useful memorised family-count phrases:",
      "examples": [
        "Mam siostrę. = I have a sister.",
        "Mam dwie/trzy/cztery siostry. = I have two/three/four sisters.",
        "Mam brata. = I have a brother.",
        "Mam dwóch/trzech/czterech braci. = I have two/three/four brothers."
      ]
    },
    {
      "id": 30,
      "topic": "piec_present_tense",
      "content": "The verb 'piec' (to bake) is irregular in the present tense.",
      "tables": {
        "present_tense": {
          "ja": "piekę",
          "ty": "pieczesz",
          "on_ona_ono": "piecze",
          "my": "pieczemy",
          "wy": "pieczecie",
          "oni_one": "pieką"
        }
      }
    },
    {
      "id": 33,
      "topic": "bratanek_vs_siostrzeniec_and_bratanica_vs_siostrzenica",
      "content": "Both 'bratanek' and 'siostrzeniec' mean 'nephew', but the first is brother's son and the second is sister's son. Similarly, 'bratanica' is brother's daughter and 'siostrzenica' is sister's daughter.",
      "examples": [
        "siostrzeniec = son of your sister",
        "bratanek = son of your brother",
        "siostrzenica = daughter of your sister",
        "bratanica = daughter of your brother"
      ]
    }
  ],
