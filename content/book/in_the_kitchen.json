  "tips": [
    {
      "id": 1,
      "topic": "szklanka_vs_kieliszek",
      "content": "Both 'szklanka' and 'kieliszek' can translate as glass in English. 'Szklanka' is a larger drinking glass for water, juice, or beer; 'kieliszek' is a small glass usually for alcoholic drinks."
    },
    {
      "id": 4,
      "topic": "ostatni_vs_ostatnio_and_garnki",
      "content": "Do not confuse the adjective 'ostatni' (last) with the adverb 'ostatnio' (lately, recently). Also remember that 'garnki' is the plural of 'garnek'."
    },
    {
      "id": 7,
      "topic": "wymienic_accusative",
      "content": "After the verb 'wymienić' (to replace), use the accusative."
    },
    {
      "id": 9,
      "topic": "prosze_often_omitted",
      "content": "In Polish, 'proszę' is not used as often as English 'please'. A sentence like '(Czy) możesz przynieść talerz?' sounds natural without 'proszę', though adding it makes it more polite or formal."
    },
    {
      "id": 11,
      "topic": "myslec_ze_with_comma",
      "content": "After 'myśleć' (to think), use 'że' and place a comma before it.",
      "examples": [
        "Myślę, że to jest piękne."
      ]
    },
    {
      "id": 12,
      "topic": "other_coffee_devices",
      "content": "Other coffee-brewing devices:",
      "examples": [
        "kawiarka = moka pot",
        "zaparzacz do kawy = cafetière / French press",
        "ekspres przelewowy = drip coffee maker"
      ]
    },
    {
      "id": 14,
      "topic": "noz_plural",
      "content": "The plural of 'nóż' (knife) is 'noże'."
    },
    {
      "id": 16,
      "topic": "widziec_accusative",
      "content": "Use the accusative after the verb 'widzieć' (to see)."
    },
    {
      "id": 18,
      "topic": "used_to_in_polish",
      "content": "There is no direct equivalent of English 'used to' in Polish. In this type of sentence, use either the past tense or 'kiedyś' (once / back then). Usually the locative is used after 'w'."
    },
    {
      "id": 19,
      "topic": "prosic_o_accusative",
      "content": "After 'prosić o' (to ask for), use the accusative."
    },
    {
      "id": 20,
      "topic": "potrzebowac_genitive",
      "content": "After the verb 'potrzebować' (to need), use the genitive."
    },
    {
      "id": 21,
      "topic": "wcale_vs_w_ogole",
      "content": "'At all' can be translated as either 'wcale' or 'w ogóle'."
    },
    {
      "id": 22,
      "topic": "wlozyc_do_genitive",
      "content": "The verb 'włożyć' is often followed by the preposition 'do' and the genitive when putting something somewhere."
    },
    {
      "id": 24,
      "topic": "w_promocji",
      "content": "'Być w promocji' means 'to be on special offer'.",
      "examples": [
        "Ta miska jest w promocji. = This bowl is on special offer."
      ]
    },
    {
      "id": 25,
      "topic": "can_you_pass_me_pattern",
      "content": "Memorise this useful pattern:",
      "examples": [
        "(Czy) możesz mi podać...? = Can you pass me...?"
      ]
    },
    {
      "id": 29,
      "topic": "jeszcze_jeden_jedna_jedno",
      "content": "'Jeszcze jeden/jedna/jedno' means 'one more' or 'another'. The form changes with gender, and only the feminine form changes its ending in the accusative.",
      "examples": [
        "Poproszę jeszcze jeden sok. = One more juice, please.",
        "Poproszę jeszcze jedną kawę. = One more coffee, please.",
        "Poproszę jeszcze jedno mleko. = One more carton/portion of milk, please."
      ]
    },
    {
      "id": 30,
      "topic": "wyrzucic_smieci",
      "content": "'Wyrzucić śmieci' means 'to throw away / take out the rubbish'."
    },
    {
      "id": 32,
      "topic": "degrees_temperature",
      "content": "With temperatures, numbers ending in 2, 3, or 4 usually take 'stopnie', and other numbers take 'stopni'. One degree is 'jeden stopień'.",
      "examples": [
        "24 stopnie",
        "21 stopni",
        "180 stopni"
      ]
    }
  ],
