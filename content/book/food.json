  "tips": [
    {
      "id": 1,
      "topic": "salata_vs_salatka",
      "content": "Do not confuse 'sałata' (lettuce) with 'sałatka' (salad).",
      "examples": [
        "ciasto (cake) vs ciastko (biscuit)",
        "biuro (office) vs biurko (desk)",
        "kanapa (couch) vs kanapka (sandwich)"
      ]
    },
    {
      "id": 1,
      "topic": "types_of_salad",
      "content": "Examples of salad types:",
      "examples": [
        "sałatka grecka = Greek salad",
        "sałatka owocowa = fruit salad",
        "sałatka Cezar = Caesar salad"
      ]
    },
    {
      "id": 2,
      "topic": "bread_is_countable",
      "content": "In Polish, 'chleb' is countable. You can say 'proszę dwa chleby' or 'proszę dwa bochenki chleba'."
    },
    {
      "id": 2,
      "topic": "moge_and_requests",
      "content": "'możesz' can translate as 'you can'. For now, you can learn the full present tense of 'móc' from the book. Unlike English, you do not always need to add 'proszę' when making a request.",
      "tables": {
        "present_tense_moc": {
          "ja": "mogę",
          "ty": "możesz",
          "on_ona_ono": "może",
          "my": "możemy",
          "wy": "możecie",
          "oni_one": "mogą"
        }
      },
      "examples": [
        "Czy możesz otworzyć okno? = Can you open the window?"
      ]
    },
    {
      "id": 4,
      "topic": "rano_not_w_rano",
      "content": "Say 'rano' for 'in the morning', not 'w rano'."
    },
    {
      "id": 7,
      "topic": "prosic_accusative",
      "content": "After 'prosić' (to ask for), use the accusative. The book notes that at this stage, using the basic form may still often be understood, but accusative is the target structure."
    },
    {
      "id": 10,
      "topic": "favourite_question_pattern",
      "content": "For questions like 'What is your favourite ...?', do not start with 'co'. Use 'jaki / jaka / jakie'.",
      "examples": [
        "Jaki jest twój ulubiony sok?"
      ]
    },
    {
      "id": 10,
      "topic": "popular_soups",
      "content": "Examples of popular soups in Poland:",
      "examples": [
        "zupa pomidorowa = tomato soup",
        "żurek = sour rye soup",
        "zupa jarzynowa = vegetable soup",
        "rosół = chicken broth/soup",
        "zupa ogórkowa = dill pickle soup",
        "barszcz czerwony = beetroot soup, borscht"
      ]
    },
    {
      "id": 12,
      "topic": "miec_ochote_na",
      "content": "Use the preposition 'na' after 'mieć ochotę' and then the accusative.",
      "examples": [
        "Mam ochotę na kakao. = I feel like having some cocoa."
      ]
    },
    {
      "id": 12,
      "topic": "jest_meaning",
      "content": "'jest' can mean either 'is' or 'there is', depending on context."
    },
    {
      "id": 13,
      "topic": "mam_czas_vs_nie_mam_czasu",
      "content": "'Mam czas.' means 'I have time.' 'Nie mam czasu.' means 'I don't have time.'"
    },
    {
      "id": 14,
      "topic": "chciec_accusative",
      "content": "Use the accusative after the verb 'chcieć' (to want)."
    },
    {
      "id": 16,
      "topic": "crisps_vs_chips_vs_fries",
      "content": "'czipsy' means crisps (UK) / chips (US), while 'frytki' means chips (UK) / fries (US)."
    },
    {
      "id": 20,
      "topic": "types_of_oil",
      "content": "Examples of oils:",
      "examples": [
        "olej słonecznikowy = sunflower oil",
        "oliwa = olive oil",
        "olej kokosowy = coconut oil"
      ]
    },
    {
      "id": 22,
      "topic": "uczulony_na_and_seafood",
      "content": "After 'uczulony' (allergic), use the preposition 'na'. 'owoce morza' literally means 'sea fruits'.",
      "examples": [
        "homar = lobster",
        "małże = clams",
        "ośmiornica = octopus",
        "mule = mussels",
        "ostrygi = oysters",
        "kalmary = squid",
        "krewetki = prawns, shrimps"
      ]
    },
    {
      "id": 24,
      "topic": "adjectives_for_good_food",
      "content": "Useful adjectives for good food:",
      "examples": [
        "pyszny = delicious",
        "smaczny = tasty",
        "dobry = good",
        "niezły = not bad, pretty good"
      ]
    },
    {
      "id": 26,
      "topic": "slodzic",
      "content": "'słodzić' means 'to take sugar'."
    },
    {
      "id": 27,
      "topic": "wegetarianin_vs_wegetarianka",
      "content": "A woman would say 'jestem wegetarianką'."
    },
    {
      "id": 29,
      "topic": "popular_polish_cakes",
      "content": "Examples of popular Polish cakes:",
      "examples": [
        "sernik = cheesecake",
        "makowiec = poppy seed cake",
        "szarlotka = apple pie",
        "piernik = gingerbread cake",
        "ciasto drożdżowe = yeast cake",
        "babka = bundt cake"
      ]
    },
    {
      "id": 33,
      "topic": "dobry_lepszy_najlepszy_and_spaghetti",
      "content": "'dobry' means good, 'lepszy' means better, and 'najlepszy' means the best. 'spaghetti' is a neuter noun, so use neuter adjective endings.",
      "examples": [
        "dobre spaghetti"
      ]
    },
    {
      "id": 35,
      "topic": "smakowac_uses_adverbs",
      "content": "With 'smakować' (to taste), use adverbs instead of adjectives, unlike English.",
      "examples": [
        "To dobrze smakuje. = It tastes good.",
        "dobry / świetny are adjectives; dobrze / świetnie are adverbs"
      ]
    }
  ],
