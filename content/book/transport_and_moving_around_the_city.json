  "tips": [
    {
      "id": 1,
      "topic": "mozna_vs_moc",
      "content": "'Można' can mean it's allowed, it's possible, one can, or may, and does not specify a person. 'Móc' should be conjugated when asking about a specific person's ability or permission.",
      "examples": [
        "Można tutaj parkować. = It's allowed / OK to park here.",
        "Czy można wejść? = Can/May I come in, please?"
      ]
    },
    {
      "id": 4,
      "topic": "instrumental_for_means_of_transport",
      "content": "In Polish, means of transport are usually expressed with the instrumental case, not with a preposition equivalent to English 'by'.",
      "tables": {
        "transport_forms": [
          ["samochód", "samochodem", "by car"],
          ["autobus", "autobusem", "by bus"],
          ["tramwaj", "tramwajem", "by tram"],
          ["pociąg", "pociągiem", "by train"]
        ]
      }
    },
    {
      "id": 4,
      "topic": "jechac_present_tense",
      "content": "Present tense of the irregular verb 'jechać' (to go using land transport):",
      "tables": {
        "present_tense": {
          "ja": "jadę",
          "ty": "jedziesz",
          "on_ona_ono": "jedzie",
          "my": "jedziemy",
          "wy": "jedziecie",
          "oni_one": "jadą"
        }
      }
    },
    {
      "id": 6,
      "topic": "lodz_city_and_boat",
      "content": "'Łódź' means boat, but it is also the name of one of the largest Polish cities."
    },
    {
      "id": 10,
      "topic": "wejscie_vs_wyjscie",
      "content": "Useful contrast:",
      "examples": [
        "wejście = entrance",
        "wyjście = exit",
        "wjazd = car park entrance / entry",
        "wyjazd = car park exit / departure by vehicle"
      ]
    },
    {
      "id": 11,
      "topic": "w_godzinach_szczytu",
      "content": "'w godzinach szczytu' means 'in the rush hour / at peak hours'. 'zatłoczony' means crowded."
    },
    {
      "id": 12,
      "topic": "odjezdzac_i_przyjezdzac",
      "content": "For trains and buses, use 'odjeżdżać' (to leave, depart) and 'przyjeżdżać' (to arrive)."
    },
    {
      "id": 14,
      "topic": "peron_and_tracks",
      "content": "Each platform has two tracks. If you go somewhere by train, it helps to know both the platform and the track the train departs from."
    },
    {
      "id": 18,
      "topic": "miejsce_meanings",
      "content": "'Miejsce' can mean seat, but also place, spot, or space."
    },
    {
      "id": 21,
      "topic": "poltora_poltorej",
      "content": "'Półtora' and 'półtorej' mean one and a half. Use 'półtorej' with feminine nouns and 'półtora' with most other nouns. The noun after them takes the genitive.",
      "examples": [
        "półtorej godziny = one and a half hours",
        "półtora litra = one and a half litres"
      ]
    },
    {
      "id": 25,
      "topic": "ticket_types",
      "content": "Useful public transport ticket types:",
      "examples": [
        "ulgowy = reduced-fare",
        "normalny = regular/normal",
        "miesięczny = monthly",
        "krótkookresowy = short-term",
        "dobowy = one-day",
        "grupowy = group",
        "weekendowy = weekend"
      ]
    },
    {
      "id": 27,
      "topic": "seat_expressions",
      "content": "Useful seat phrases:",
      "examples": [
        "miejsce przy oknie = window seat",
        "miejsce przy przejściu/korytarzu = aisle seat",
        "miejsce pośrodku = middle seat"
      ]
    },
    {
      "id": 29,
      "topic": "formal_pan_pani_after_przepraszam",
      "content": "Use 'pana' or 'panią' after 'przepraszam' in formal direct address because the accusative is used.",
      "examples": [
        "Przepraszam pana, gdzie mogę kupić bilet?",
        "Przepraszam panią, kiedy odjeżdża ten autobus?"
      ]
    },
    {
      "id": 33,
      "topic": "dlugo_not_dlugi_czas",
      "content": "For 'for a long time', Polish often uses the adverb 'długo', not the phrase 'długi czas'."
    }
  ],
