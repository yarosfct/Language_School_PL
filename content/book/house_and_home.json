  "tips": [
    {
      "id": 1,
      "topic": "apartament_meaning",
      "content": "The Polish noun 'apartament' means suite, penthouse, or a high-standard flat/apartment, not an ordinary apartment."
    },
    {
      "id": 3,
      "topic": "okna_plural",
      "content": "'Okna' (windows) is the plural form of 'okno' (window)."
    },
    {
      "id": 4,
      "topic": "adjectives_for_flats_and_houses",
      "content": "Useful adjectives describing a flat or a house:",
      "examples": [
        "duży = big",
        "mały = small",
        "przytulny = cosy",
        "przestronny = spacious",
        "nowoczesny = modern",
        "wygodny = comfortable",
        "jasny = bright, light"
      ]
    },
    {
      "id": 6,
      "topic": "slyszec_vs_sluchac",
      "content": "Do not confuse 'słyszeć' (to hear) with 'słuchać' (to listen)."
    },
    {
      "id": 8,
      "topic": "mebel_vs_meble",
      "content": "'Mebel' means a single piece of furniture. 'Meble' means furniture in general and is treated as plural in Polish.",
      "examples": [
        "Te meble są piękne. = This furniture is beautiful."
      ]
    },
    {
      "id": 11,
      "topic": "duzy_pokoj_as_alternative",
      "content": "Instead of 'salon', you can also hear 'duży pokój' for living room."
    },
    {
      "id": 13,
      "topic": "skorzystac_z",
      "content": "'Skorzystać' is often close in meaning to 'używać', but in contexts like using the toilet or a room you use 'skorzystać z'. After 'skorzystać', use the preposition 'z' and the genitive."
    },
    {
      "id": 14,
      "topic": "nie_chce_mi_sie",
      "content": "'Nie chce mi się...' can be translated as 'I don't feel like...', especially when you are too lazy or unwilling to do something."
    },
    {
      "id": 14,
      "topic": "pietro_vs_podloga",
      "content": "English 'floor' can translate as either 'piętro' or 'podłoga'. 'Piętro' refers to a level/storey of a building, while 'podłoga' is the surface you walk on."
    },
    {
      "id": 16,
      "topic": "locative_after_w",
      "content": "After the preposition 'w', Polish usually uses the locative case.",
      "tables": {
        "locative_examples": [
          ["mieszkanie", "w mieszkaniu"],
          ["kuchnia", "w kuchni"],
          ["łazienka", "w łazience"],
          ["sypialnia", "w sypialni"],
          ["salon", "w salonie"],
          ["gabinet", "w gabinecie"],
          ["ogród", "w ogrodzie"],
          ["pokój", "w pokoju"]
        ]
      }
    },
    {
      "id": 24,
      "topic": "miejsce_space_vs_room",
      "content": "Here 'miejsce' means space, not room. It can mean seat, place, spot, or space depending on context."
    },
    {
      "id": 25,
      "topic": "a_for_contrast",
      "content": "The conjunction 'a' is often used like English 'and' when emphasizing a contrast between two parts of a sentence.",
      "examples": [
        "Jego dom jest duży, a mój jest mały. = His house is big, and mine is small."
      ]
    },
    {
      "id": 26,
      "topic": "neighbor_gender_forms",
      "content": "Useful neighbour forms:",
      "examples": [
        "sąsiad = male neighbour",
        "sąsiadka = female neighbour",
        "sąsiedzi = male neighbours / mixed group of neighbours"
      ]
    },
    {
      "id": 26,
      "topic": "co_as_every",
      "content": "'Co' can also mean 'every' in frequency expressions.",
      "examples": [
        "Robię zakupy co tydzień. = I do the shopping every week.",
        "Co wtorek chodzę na siłownię. = I go to the gym every Tuesday."
      ]
    },
    {
      "id": 27,
      "topic": "parter",
      "content": "'Parter' means ground floor. In Poland, lift/elevator buttons often use the letter 'P' for 'parter'."
    },
    {
      "id": 31,
      "topic": "bardziej_vs_wiecej",
      "content": "'Bardziej' is mainly used with adjectives to talk about a higher intensity. 'Więcej' is used with nouns in the genitive and refers to a larger amount or number.",
      "examples": [
        "On jest bardziej zmęczony niż ja. = He is more tired than me.",
        "W tym mieszkaniu jest więcej pokoi. = There are more rooms in this flat.",
        "Ostatnio więcej gotuję. = Recently I've been cooking more."
      ]
    },
    {
      "id": 33,
      "topic": "zamkniete_na_klucz_and_drzwi_plural",
      "content": "'Zamknięte na klucz' means locked. 'Drzwi' (door) is always a plural noun in Polish.",
      "examples": [
        "drzwi wejściowe = front door",
        "tylne drzwi = back door"
      ]
    },
    {
      "id": 34,
      "topic": "wlaczyc_vs_wylaczyc",
      "content": "'Włączyć' means to turn on and 'wyłączyć' means to turn off. After both verbs, use the accusative."
    }
  ],
