  "tips": [
    {
      "id": 1,
      "topic": "kraj_as_country_or_state",
      "content": "A synonym for the noun 'kraj' (country) is 'państwo'. In different contexts, 'państwo' can also be a formal form of address meaning 'you' (plural/polite)."
    },
    {
      "id": 2,
      "topic": "na_swiecie_not_w_swiecie",
      "content": "Say 'na świecie' for 'in the world', not 'w świecie'."
    },
    {
      "id": 3,
      "topic": "sun_related_phrases",
      "content": "Useful sun-related phrases:",
      "examples": [
        "wschód słońca = sunrise",
        "zachód słońca = sunset",
        "wschodzić = to rise",
        "zachodzić = to set"
      ]
    },
    {
      "id": 4,
      "topic": "names_of_oceans",
      "content": "Polish names of the oceans:",
      "examples": [
        "Ocean Atlantycki = the Atlantic Ocean",
        "Ocean Arktyczny = the Arctic Ocean",
        "Ocean Spokojny = the Pacific Ocean",
        "Ocean Indyjski = the Indian Ocean",
        "Ocean Południowy = the Southern Ocean"
      ]
    },
    {
      "id": 9,
      "topic": "antarktyda_phrase",
      "content": "You can say 'Antarktyda' or 'największa pustynia na świecie' in the sentence about Antarctica."
    },
    {
      "id": 11,
      "topic": "sciagac_synonym",
      "content": "Remember that 'ściągać' (to download) is a synonym of 'pobierać'."
    },
    {
      "id": 12,
      "topic": "continents_names",
      "content": "Names of all the continents:",
      "examples": [
        "Azja = Asia",
        "Europa = Europe",
        "Afryka = Africa",
        "Australia = Australia",
        "Ameryka Północna = North America",
        "Ameryka Południowa = South America",
        "Antarktyda = Antarctica"
      ]
    },
    {
      "id": 14,
      "topic": "zmienilem_zdanie",
      "content": "Memorise: 'Zmieniłem (f.) zdanie' = 'I changed my mind.'"
    },
    {
      "id": 15,
      "topic": "na_do_nad_for_places",
      "content": "To learn more about when to use 'na', 'do', and 'nad' with places, see the book's grammar notes. This section uses several travel/place patterns."
    },
    {
      "id": 16,
      "topic": "after_znalezc_accusative",
      "content": "After the verb 'znaleźć' (to find), use the accusative case."
    },
    {
      "id": 18,
      "topic": "na_plus_locative_with_seasons",
      "content": "In the sentence about spring or winter, after the preposition 'na', use the locative case."
    },
    {
      "id": 18,
      "topic": "na_plus_locative_with_moon",
      "content": "In the sentence with 'look at the moon', the note says to use 'na' with the accusative for looking at something."
    },
    {
      "id": 19,
      "topic": "seasons_mistakes",
      "content": "Do not confuse 'wiosna' and 'zima'. Also remember:",
      "examples": [
        "jesienią = in the autumn",
        "latem = in the summer"
      ]
    },
    {
      "id": 20,
      "topic": "directions_with_na",
      "content": "With names of directions, Polish uses 'na':",
      "examples": [
        "na północ = north",
        "na południe = south",
        "na zachód = west",
        "na wschód = east"
      ],
      "content_note": "The note also pairs these with movement verbs and state/location verbs."
    },
    {
      "id": 24,
      "topic": "nad_and_po_for_bodies_of_water",
      "content": "Use the preposition 'nad' before names of bodies of water like a lake or sea.",
      "examples": [
        "nad jeziorem = by the lake",
        "nad morzem = by the sea"
      ]
    },
    {
      "id": 24,
      "topic": "jesienia_accusative",
      "content": "After 'lubić' (to like), use the accusative case."
    },
    {
      "id": 29,
      "topic": "planet_names",
      "content": "Planet names:",
      "examples": [
        "Jowisz = Jupiter",
        "Saturn = Saturn",
        "Wenus = Venus",
        "Mars = Mars",
        "Merkury = Mercury"
      ]
    },
    {
      "id": 32,
      "topic": "o_plus_locative_when_many_places",
      "content": "In sentences with 'o' referring to many places, use the locative plural."
    },
    {
      "id": 33,
      "topic": "nie_moge_sie_doczekac",
