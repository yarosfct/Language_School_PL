  "tips": [
    {
      "id": 1,
      "topic": "present_tense_basics",
      "content": "Polish has one present tense. To form it, remove the infinitive ending (usually -ć) and add endings. Simplified pattern: ja: -m/-ę, ty: -sz, on/ona/ono: often based on the ty form without -sz, my: -my, wy: -cie, oni/one: -ją/-ą.",
      "examples": [
        "robić -> robię, robisz, robi, robimy, robicie, robią",
        "czytać -> czytam, czytasz, czyta, czytamy, czytacie, czytają"
      ]
    },
    {
      "id": 3,
      "topic": "watch_netflix",
      "content": "To watch Netflix is translated as 'oglądać Netflixa', not 'oglądać Netflix'."
    },
    {
      "id": 7,
      "topic": "word_order",
      "content": "Polish word order can differ from English. The book uses the most natural-sounding Polish order. English-like order may still be understandable, but can sound awkward."
    },
    {
      "id": 8,
      "topic": "short_words_at_sentence_end",
      "content": "If the word 'to' (it) appears in a sentence with at least two other words, it should not be placed directly before the full stop. The same often applies to 'nic' and 'tu/tutaj'. Avoid ending sentences with very short words when possible."
    },
    {
      "id": 10,
      "topic": "czekac_with_na",
      "content": "The verb 'czekać' is usually followed by the preposition 'na'.",
      "examples": [
        "czekać na autobus",
        "czekać na spotkanie"
      ]
    },
    {
      "id": 11,
      "topic": "niestety_vs_na_szczescie",
      "content": "'niestety' means 'unfortunately'; 'na szczęście' means 'fortunately'."
    },
    {
      "id": 12,
      "topic": "double_negative",
      "content": "Polish requires a double negative, unlike English.",
      "examples": [
        "Nigdy nie piję kawy. = I never drink coffee."
      ]
    },
    {
      "id": 15,
      "topic": "verbs_with_owac",
      "content": "If the infinitive contains '-owa-' (e.g. pracować, gotować), in conjugation it usually changes to '-uj-'.",
      "examples": [
        "pracować -> pracuję, pracujesz, pracuje, pracujemy, pracujecie, pracują"
      ]
    },
    {
      "id": 18,
      "topic": "dziekowac_za",
      "content": "If you want to be specific about what you are thanking for, use 'za' after 'dziękować'.",
      "examples": [
        "Dziękuję za te piękne kwiaty. = Thank you for these beautiful flowers."
      ]
    },
    {
      "id": 19,
      "topic": "questions_with_czy",
      "content": "You can say 'Czy tu studiujesz?' or 'Czy pracujesz?'. In spoken Polish, 'czy' is often omitted and a question is formed by intonation."
    },
    {
      "id": 21,
      "topic": "stad",
      "content": "'stąd' means 'from here' or sometimes 'here'. It is related to 'skąd' meaning 'where from'."
    },
    {
      "id": 22,
      "topic": "placement_of_sie",
      "content": "With verbs containing 'się', it is often more natural not to leave 'się' at the very end of the sentence if there are more than two words.",
      "examples": [
        "Lubię się uczyć. (more natural)",
        "Lubię uczyć się. (less natural)"
      ]
    },
    {
      "id": 23,
      "topic": "two_verbs_rule",
      "content": "If two verbs come one after another in one sentence, only the first one is conjugated."
    },
    {
      "id": 24,
      "topic": "byc_and_miec_irregular",
      "content": "The verbs 'być' and 'mieć' are irregular.",
      "tables": {
        "byc": {
          "ja": "jestem",
          "ty": "jesteś",
          "on_ona_ono": "jest",
          "my": "jesteśmy",
          "wy": "jesteście",
          "oni_one": "są"
        },
        "miec": {
          "ja": "mam",
          "ty": "masz",
          "on_ona_ono": "ma",
          "my": "mamy",
          "wy": "macie",
          "oni_one": "mają"
        }
      }
    },
    {
      "id": 28,
      "topic": "przepraszam_vs_przykro_mi",
      "content": "Use 'przepraszam' when apologising for something. Use 'przykro mi' when you feel sorry for someone or sympathise with them.",
      "examples": [
        "Przepraszam. = I'm sorry.",
        "Przykro mi, że jesteś chory. = I'm sorry that you're ill."
      ]
    },
    {
      "id": 33,
      "topic": "ze_is_required",
      "content": "When expressing an opinion, 'że' is obligatory in Polish even when 'that' is optional in English. In writing, use a comma before 'że'."
    },
    {
      "id": 35,
      "topic": "slyszec_vs_sluchac",
      "content": "Do not add 'móc' before verbs of the senses the way English does. Also do not confuse 'słyszeć' (to hear) with 'słuchać' (to listen).",
      "examples": [
        "Nie słyszę cię. = I can't hear you.",
        "Czy widzisz Adama? = Can you see Adam?"
      ]
    }
  ],
