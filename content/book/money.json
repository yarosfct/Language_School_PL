  "tips": [
    {
      "id": 1,
      "topic": "polish_currency",
      "content": "The Polish currency is the złoty. Banknotes exist in denominations such as 10, 20, 50, 100, 200, and 500 złotych; coins include grosze and złote values.",
      "examples": [
        "10 złotych",
        "20 złotych",
        "50 złotych",
        "100 złotych",
        "200 złotych",
        "500 złotych",
        "1 grosz",
        "2 grosze",
        "5 groszy",
        "10 groszy",
        "20 groszy",
        "50 groszy",
        "1 złoty",
        "2 złote",
        "5 złotych"
      ]
    },
    {
      "id": 2,
      "topic": "konto_bankowe",
      "content": "'Konto bankowe' means bank account."
    },
    {
      "id": 3,
      "topic": "card_types",
      "content": "Common card types:",
      "examples": [
        "karta kredytowa = credit card",
        "karta debetowa = debit card"
      ],
      "content_note": "The book notes that 'płacić kartą' translates as 'to pay by card'."
    },
    {
      "id": 4,
      "topic": "grosz_and_zloty_number_forms",
      "content": "The noun forms change with numbers. The book highlights the patterns for złoty and grosz.",
      "examples": [
        "1 złoty",
        "2/3/4 złote",
        "5/6/7/8/9/10/11... złotych",
        "1 grosz",
        "2/3/4 grosze",
        "5/6/7/8/9/10/11... groszy"
      ]
    },
    {
      "id": 5,
      "topic": "po_plus_accusative_with_coin",
      "content": "In a shop, if you ask for one 1-złoty coin, use 'po' rather than just the accusative of 'złoty'.",
      "examples": [
        "Czy ma pan złotówkę?",
        "Czy ma pani złotówkę?"
      ]
    },
    {
      "id": 6,
      "topic": "wymienic_na",
      "content": "After the verb 'wymienić' (to exchange), use the preposition 'na'.",
      "examples": [
        "Chciałbym wymienić złotówki na euro.",
        "Lubię wymieniać funty na złotówki."
      ]
    },
    {
      "id": 7,
      "topic": "cash_machine_names",
      "content": "Informally, especially among younger people, a cash machine can also be called:",
      "examples": [
        "kasa",
        "forśe",
        "cash"
      ]
    },
    {
      "id": 8,
      "topic": "cost_question_forms",
      "content": "If you want to ask or tell somebody about the price of an item, use 'kosztować'. The book also points out another common price question pattern.",
      "examples": [
        "Herbata kosztuje 10 złotych.",
        "Ile jest wody?"
      ],
      "content_note": "The book notes that asking a total price can also be done with structures introduced earlier."
    },
    {
      "id": 18,
      "topic": "wydawac_na",
      "content": "To spend can translate as 'spędzać' or 'wydawać' in different contexts. Here 'wydawać' is used with the preposition 'na', so 'wydawać na' means 'to spend on'."
    },
    {
      "id": 25,
      "topic": "dostawac_accusative",
      "content": "After 'dostawać' (to get), use the accusative case."
    },
    {
      "id": 27,
      "topic": "comparative_superlative_money_reference",
      "content": "The note points learners to the comparative and superlative of adjectives for more on forms like 'wyższa pensja'."
    },
    {
      "id": 28,
      "topic": "napiwek_not_obligatory",
      "content": "Tipping in Polish restaurants is not mandatory. If service is very good, it is common to leave around 10–15% of the total bill."
    },
    {
      "id": 30,
      "topic": "near_here_expressions",
      "content": "You can translate 'near here' as:",
      "examples": [
        "w okolicy",
        "w pobliżu",
        "niedaleko"
      ]
    },
    {
      "id": 31,
      "topic": "pozyczac_meanings",
      "content": "The verb 'pożyczać' can mean to borrow, to loan, or to lend depending on context."
    },
    {
      "id": 32,
      "topic": "pozyczac_od_genitive",
      "content": "Remember to use the genitive case after 'od' (from)."
    },
    {
      "id": 34,
      "topic": "w_plus_locative",
      "content": "After the preposition 'w', usually the locative case is used.",
      "examples": [
        "w torbie"
      ]
    },
    {
      "id": 34,
      "topic": "discount_synonyms",
      "content": "In shops, you may see these nouns for discount; they are treated as near-synonyms here:",
      "examples": [
        "zniżka",
        "rabat",
        "obniżka"
      ]
    }
  ],
