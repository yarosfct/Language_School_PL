  "tips": [
    {
      "id": 1,
      "topic": "hotel_and_bank_no_to_jest_needed",
      "content": "In many sentences with 'there is/there are' or simple identification, Polish often omits 'to jest'.",
      "examples": [
        "To jest hotel. = a to jest hotel.",
        "To jest bank. = a to jest bank."
      ]
    },
    {
      "id": 2,
      "topic": "on_vs_jej",
      "content": "The note reminds that 'on' and 'jej' can look identical in English translations depending on context, but are different in Polish grammar."
    },
    {
      "id": 3,
      "topic": "widok_na",
      "content": "To say 'view of/onto', use 'widok na' + accusative.",
      "examples": [
        "widok na morze = sea view",
        "widok na góry = mountain view",
        "widok na las = forest view"
      ],
      "content_note": "The book notes that 'widok' is a singular noun."
    },
    {
      "id": 4,
      "topic": "miec_nadzieje",
      "content": "To hope can be translated as 'mieć nadzieję'. It literally means 'to have hope'."
    },
    {
      "id": 5,
      "topic": "room_capacity_forms",
      "content": "Useful room-capacity forms:",
      "examples": [
        "jednoosobowy = one-person / single",
        "dwuosobowy = two-person / double",
        "trzyosobowy = triple",
        "czteroosobowy = quadruple"
      ]
    },
    {
      "id": 6,
      "topic": "jestesmy_here_you_are_welcome",
      "content": "In this context, 'Jesteśmy' can correspond to 'you’re welcome' in response after helping someone."
    },
    {
      "id": 7,
      "topic": "wycieczka_plural",
      "content": "The plural of 'wycieczka' is 'wycieczki'."
    },
    {
      "id": 8,
      "topic": "jechac_nad_morze_w_gory",
      "content": "When talking about going to the sea, lake, ocean, or river, use 'nad' + accusative. When talking about going to the mountains, use 'w' + accusative.",
      "examples": [
        "jechać nad morze/ocean/rzekę/jezioro",
        "jechać w góry/Alpy/Tatry"
      ]
    },
    {
      "id": 11,
      "topic": "passport_object_pronoun_before_noun",
      "content": "In Polish, when a noun belongs to someone, it can sound more natural to place the pronoun before the noun in some contexts, especially with objects.",
      "examples": [
        "twój paszport"
      ]
    },
    {
      "id": 12,
      "topic": "surnames_ending_in_ski",
      "content": "Polish surnames ending in -ski can take masculine or feminine endings.",
      "examples": [
        "Adam Kowalski",
        "Anna Kowalska"
      ],
      "content_note": "The same applies to other common surname endings, e.g. -ów, -ak, etc., depending on name patterns."
    },
    {
      "id": 13,
      "topic": "pakowac_vs_rozpakowac",
      "content": "Useful contrast:",
      "examples": [
        "pakować = to pack",
        "rozpakować = to unpack"
      ]
    },
    {
      "id": 17,
      "topic": "pamietac_from_pamietac",
      "content": "The noun 'pamiątka' (souvenir) originates from the verb 'pamiętać' (to remember)."
    },
    {
      "id": 18,
      "topic": "pan_forms",
      "content": "Formal address uses 'pan' (masculine) and 'pani' (feminine).",
      "examples": [
        "Czy to jest pani paszport?",
        "Czy to jest pan paszport?"
      ],
      "content_note": "The second example in the printed note is somewhat awkwardly phrased; the formal pattern itself is the important part."
    },
    {
      "id": 19,
      "topic": "za_granice_vs_za_granica",
      "content": "'Za granicę' means abroad in the sense of movement to another country. 'Za granicą' refers to being abroad / location.",
      "examples": [
        "Jadę za granicę na wakacje.",
        "Mój kolega mieszka za granicą."
      ]
    },
    {
      "id": 20,
      "topic": "zwiedzac_vs_odwiedzac",
      "content": "The verb 'to visit' can translate as 'zwiedzać' or 'odwiedzać', depending on whether you mean sightseeing places or visiting people/places more generally."
    },
    {
      "id": 21,
      "topic": "holiday_accommodation_words",
      "content": "Some place names connected with accommodation on holiday:",
      "examples": [
        "kemping = camping site",
        "ośrodek wczasowy = holiday centre",
        "gospodarstwo agroturystyczne = agritourism farm"
      ]
    },
    {
      "id": 22,
      "topic": "flight_change_words",
      "content": "Useful flight-related words:",
      "examples": [
        "lot z przesiadką = one-stop / connecting flight",
        "przesiadka = change / transfer"
      ]
    },
    {
      "id": 23,
      "topic": "ticket_collocations",
      "content": "Useful ticket collocations:",
      "examples": [
        "bilet w jedną stronę = one-way ticket",
        "bilet powrotny = return ticket",
        "bilet ulgowy = reduced-fare ticket",
        "bilet normalny = regular ticket"
      ]
    },
    {
      "id": 25,
      "topic": "przyjazd_vs_odjazd_vs_wyjscie",
      "content": "Useful travel movement nouns:",
      "examples": [
        "przyjazd = arrival",
        "odjazd = departure",
        "wyjście = going out / exit on foot in other contexts"
      ]
    },
    {
      "id": 26,
      "topic": "z_plus_instrumental",
      "content": "After the preposition 'z' (with), use the instrumental case.",
      "examples": [
        "z przewodnikiem"
      ]
    }
  ],
