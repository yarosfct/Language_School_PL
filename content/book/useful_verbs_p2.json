  "tips": [
    {
      "id": 2,
      "topic": "pytac_vs_prosic",
      "content": "'Pytać' and 'prosić' can both translate as 'to ask', but they are used differently. 'Prosić' is used for requests; 'pytać' is used for asking about information, details, or facts.",
      "examples": [
        "prosić o pomoc = to ask for help",
        "prosić o kawę = to ask for coffee",
        "pytać o cenę = to ask about the price",
        "pytać o godzinę = to ask the time"
      ]
    },
    {
      "id": 2,
      "topic": "accusative_after_pytac_and_prosic",
      "content": "Use the accusative after both these verbs in the patterns shown in the note."
    },
    {
      "id": 3,
      "topic": "nienawidzic_synonyms",
      "content": "Synonyms of 'nienawidzić' include 'nie cierpieć' and 'nie znosić'."
    },
    {
      "id": 6,
      "topic": "mowic_po_language",
      "content": "When listing languages someone speaks, use the preposition 'po' after 'mówić' and change the language ending to -u or -sku.",
      "examples": [
        "polski → mówić po polsku",
        "niemiecki → mówić po niemiecku",
        "hiszpański → mówić po hiszpańsku",
        "angielski → mówić po angielsku"
      ]
    },
    {
      "id": 7,
      "topic": "owa_to_uj_in_conjugation",
      "content": "Infinitive verbs ending in -ować usually change -owa- to -uj- in conjugation.",
      "examples": [
        "budować → ja buduję, ty budujesz, on buduje"
      ]
    },
    {
      "id": 8,
      "topic": "blisko_niedaleko_genitive",
      "content": "Use the genitive after 'blisko' and 'niedaleko'."
    },
    {
      "id": 8,
      "topic": "miec_nadzieje_ze",
      "content": "After 'mieć nadzieję', always use 'że'.",
      "examples": [
        "Mam nadzieję, że jutro będzie ładna pogoda."
      ]
    },
    {
      "id": 10,
      "topic": "kontynuowac_without_z",
      "content": "After 'kontynuować', do not use 'z' as English uses 'with'."
    },
    {
      "id": 10,
      "topic": "szukac_genitive_no_preposition",
      "content": "After 'szukać', use the genitive and do not use prepositions like 'dla' or 'na'."
    },
    {
      "id": 12,
      "topic": "zwiedzac_vs_odwiedzac",
      "content": "'Zwiedzać' and 'odwiedzać' can both mean 'to visit', but they differ. 'Zwiedzać' is for visiting places such as museums, landmarks, cities, or for sightseeing. 'Odwiedzać' is for visiting people or casually visiting places regularly.",
      "examples": [
        "Dzisiaj zwiedzamy Kraków. = Today we are visiting Krakow.",
        "Odwiedzam moją babcię co tydzień. = I visit my grandma every week."
      ]
    },
    {
      "id": 12,
      "topic": "accusative_after_zwiedzac_i_odwiedzac",
      "content": "After both verbs, use the accusative."
    },
    {
      "id": 12,
      "topic": "currently_translations",
      "content": "'Currently' can be translated as 'obecnie' or 'aktualnie'. Note that 'aktualnie' is a false friend of English 'actually'."
    },
    {
      "id": 14,
      "topic": "wychodzic_z_plus_genitive",
      "content": "After 'wychodzić' (to leave), use the preposition 'z' followed by the genitive case.",
      "tables": {
        "examples": [
          ["wychodzić z pracy", "to leave work"],
          ["wychodzić z domu", "to leave home"],
          ["wychodzić z banku", "to leave the bank"]
        ]
      }
    },
    {
      "id": 14,
      "topic": "o_ktorej_godzinie_shorter_version",
      "content": "'O której godzinie' means 'what time'. A shorter version, 'O której', is used in semi-formal and informal conversations."
    },
    {
      "id": 15,
      "topic": "spotkac_sie_vs_poznac",
      "content": "'To meet' usually translates as 'spotkać się' or 'poznać'. 'Spotkać się' is used for meeting someone in the sense of having a meeting / getting together; 'poznać' is often for meeting someone for the first time.",
      "examples": [
        "Wczoraj poznałem jej siostrę. = Yesterday I met her sister for the first time."
      ]
    },
    {
      "id": 18,
      "topic": "plakac_present_tense",
      "content": "The verb 'płakać' is irregular; memorise its conjugation:",
      "tables": {
        "present_tense": {
          "ja": "płaczę",
          "ty": "płaczesz",
          "on_ona_ono": "płacze",
          "my": "płaczemy",
          "wy": "płaczecie",
          "oni_one": "płaczą"
        }
      }
    },
    {
      "id": 22,
      "topic": "spedzac_vs_wydawac",
      "content": "'Spędzać' is used when talking about spending time or holidays. 'Wydawać' is used for spending money.",
      "examples": [
        "Lubię spędzać czas z rodziną.",
        "Lubię wydawać pieniądze na buty."
      ]
    },
    {
      "id": 24,
      "topic": "organizowac_accusative_and_dla_genitive",
      "content": "After 'organizować', use the accusative. After 'dla' (for), use the genitive."
    },
    {
      "id": 25,
      "topic": "juz_vs_juz_nie",
      "content": "Useful contrast:",
      "examples": [
        "już = already",
        "już nie = any more"
      ]
    },
    {
      "id": 27,
      "topic": "z_przodu_vs_z_tylu",
      "content": "Useful location phrases:",
      "examples": [
        "z przodu = in the front",
        "z tyłu = in the back"
      ]
    },
    {
      "id": 31,
      "topic": "forms_of_address_pan_pani_panstwo",
      "content": "Different forms of address are used depending on politeness and relationship. 'Ty' / 'wy' are for family, friends, and children. For strangers or polite address, use 'pan', 'pani', 'panowie', 'panie', or 'państwo'. These polite forms require the 3rd-person verb form."
    },
    {
      "id": 34,
      "topic": "a_lot_vs_duzo",
      "content": "Remember that 'a lot' is 'dużo', not 'duży'."
    }
  ],
