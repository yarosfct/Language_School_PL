  "tips": [
    {
      "id": 1,
      "topic": "aplikacja_shortened",
      "content": "Informally, 'aplikacja' can be shortened to 'apka' (app)."
    },
    {
      "id": 3,
      "topic": "rozladowana_bateria",
      "content": "You can colloquially say 'bateria padła' for 'the battery is dead/flat'."
    },
    {
      "id": 4,
      "topic": "z_plus_genitive",
      "content": "After the preposition 'z' meaning 'from', use the genitive case."
    },
    {
      "id": 5,
      "topic": "daleko_od_genitive",
      "content": "After 'blisko' and 'daleko od', use the genitive case.",
      "examples": [
        "Sklep jest blisko domu. = The shop is close to home.",
        "Sklep jest daleko od mojego domu. = The shop is far from my home."
      ]
    },
    {
      "id": 7,
      "topic": "bon_zgubic_and_stracic",
      "content": "Both 'zgubić' and 'stracić' can translate as 'to lose', but they differ. 'Zgubić' is used when you can't find something because you misplaced it. 'Stracić' can mean lose more generally, including losing money, time, a connection, an opportunity, etc."
    },
    {
      "id": 9,
      "topic": "pobrac_accusative",
      "content": "After the verb 'pobrać / pobierać' (to download), use the accusative case. A synonym is 'ściągnąć'."
    },
    {
      "id": 15,
      "topic": "email_symbols",
      "content": "In the table of email-related terms, you will also find names of symbols used in email and web addresses:",
      "examples": [
        "@ = małpa",
        ". = kropka",
        "- = myślnik",
        "_ = podkreślnik"
      ]
    },
    {
      "id": 17,
      "topic": "co_jest_nie_tak",
      "content": "The phrase 'Co jest nie tak?' translates as 'What's wrong?' and is perfectly OK. It means wrong or not right."
    },
    {
      "id": 18,
      "topic": "z_plus_instrumental",
      "content": "After the preposition 'z' meaning 'with', use the instrumental case."
    },
    {
      "id": 19,
      "topic": "w_plus_locative",
      "content": "After the preposition 'w' (where: in), usually the locative case is used."
    },
    {
      "id": 20,
      "topic": "information_uncountable",
      "content": "Unlike English, the noun 'informacja' in Polish is countable. Its plural form is 'informacje'."
    },
    {
      "id": 21,
      "topic": "with_wifi_phrase",
      "content": "You can use phrases like:",
      "examples": [
        "dobre Wi-Fi = good Wi-Fi",
        "szybkie Wi-Fi = fast Wi-Fi",
        "wolne Wi-Fi = slow Wi-Fi",
        "słabe Wi-Fi = weak Wi-Fi"
      ]
    },
    {
      "id": 22,
      "topic": "zainstalowac_accusative",
      "content": "After the verb 'zainstalować' (to install), use the accusative case."
    },
    {
      "id": 22,
      "topic": "strona_internetowa",
      "content": "'Strona internetowa' literally means internet page."
    },
    {
      "id": 26,
      "topic": "wiadomosc_feminine",
      "content": "The noun 'wiadomość' is feminine, so with this noun the form 'ta' is used."
    },
    {
      "id": 27,
      "topic": "na_plus_locative",
      "content": "After the preposition 'na' meaning 'here: on', usually the locative case is used."
    },
    {
      "id": 30,
      "topic": "na_razie",
      "content": "'Na razie' means 'for now' or 'so far', depending on context.",
      "examples": [
        "Na razie mieszkam z rodzicami. = For now I live with my parents.",
        "Na razie! Do zobaczenia! = See you later / Bye for now!"
      ]
    },
    {
      "id": 32,
      "topic": "z_plus_genitive_from",
      "content": "After the preposition 'z' meaning 'from', use the genitive case."
    },
    {
      "id": 34,
      "topic": "wiadomosc_plural",
      "content": "The noun 'wiadomość' has the plural form 'wiadomości'."
    }
  ],
